// Mulaqat core data model (IMPLEMENTATION_PLAN.md §5).
// snake_case tables, UUID v7 PKs (uuid_generate_v7() defined in the base migration),
// created_at/updated_at everywhere, soft-delete on user-generated content.
// The `ai` schema (ai.documents, ai.ingestions, ai.eval_runs) is owned by services/ai — not Prisma.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ──────────────────────────────────────────────────────────────────

enum Gender {
  woman
  man
  nonbinary
  prefer_not
}

enum Role {
  user
  host
  admin
}

enum RelationshipIntent {
  friends_only
  open_to_dating
}

enum Dietary {
  veg
  nonveg
  jain
  vegan
  eggetarian
}

enum UserStatus {
  active
  suspended
  banned
}

enum QuestionKind {
  single
  multi
  slider
  either_or
}

enum PriceBand {
  low
  mid
  high
}

enum PartnerStatus {
  prospect
  active
  paused
}

enum EventType {
  dinner
  run_club
  game_night
  chai
  trek
}

enum BudgetBand {
  budget   @map("₹")
  moderate @map("₹₹")
  premium  @map("₹₹₹")
}

enum EventStatus {
  draft
  published
  matching
  revealed
  live
  completed
  cancelled
}

enum BookingStatus {
  pending_payment
  confirmed
  waitlisted
  checked_in
  no_show
  cancelled
  refunded
}

enum PaymentStatus {
  created
  paid
  failed
  refunded
}

enum MatchRunStatus {
  running
  completed
  failed
}

enum DeckKind {
  icebreaker
  hot_takes
  most_likely
  trivia
  two_truths
}

enum DeckLocale {
  en
  hinglish
}

enum DeckSource {
  seed
  generated
  admin
}

enum DeckStatus {
  active
  draft
  retired
}

enum ConnectionKind {
  connect
  spark
}

enum ConnectionStatus {
  pending
  mutual
  expired
  declined
}

enum ChatKind {
  direct
  table_group
}

enum MessageKind {
  text
  image
  voice
}

enum ReportReason {
  harassment
  safety_concern
  fake_profile
  inappropriate_behavior
  no_show
  other
}

enum ReportStatus {
  open
  actioned
  dismissed
}

enum VerificationKind {
  selfie
  gov_id
}

enum VerificationStatus {
  pending
  approved
  rejected
}

enum SubscriptionTier {
  plus
  concierge
}

enum SubscriptionStatus {
  active
  past_due
  cancelled
}

// ── Identity & profile ─────────────────────────────────────────────────────

model User {
  id                 String              @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  phone              String              @unique
  email              String?             @unique
  fullName           String?             @map("full_name")
  firstName          String?             @map("first_name")
  dob                DateTime?           @db.Date
  gender             Gender?
  cityId             String?             @map("city_id") @db.Uuid
  photoUrl           String?             @map("photo_url")
  selfieVerified     Boolean             @default(false) @map("selfie_verified")
  idVerified         Boolean             @default(false) @map("id_verified")
  role               Role                @default(user)
  relationshipIntent RelationshipIntent? @map("relationship_intent")
  dietary            Dietary?
  languages          String[]            @default([])
  interests          String[]            @default([])
  bio                String?
  status             UserStatus          @default(active)
  deletedAt          DateTime?           @map("deleted_at")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")

  city               City?                @relation(fields: [cityId], references: [id])
  personalityProfile PersonalityProfile?
  quizResponses      QuizResponse[]
  bookings           Booking[]
  hostedEvents       Event[]              @relation("EventHost")
  matchRunsCreated   MatchRun[]           @relation("MatchRunCreator")
  matchAssignments   MatchAssignment[]
  gameSessionsStarted GameSession[]       @relation("GameStarter")
  connectionsSent    Connection[]         @relation("ConnectionFrom")
  connectionsReceived Connection[]        @relation("ConnectionTo")
  chatMemberships    ChatMember[]
  messages           Message[]
  reportsFiled       Report[]             @relation("Reporter")
  reportsReceived    Report[]             @relation("Reported")
  blocksMade         Block[]              @relation("Blocker")
  blocksReceived     Block[]              @relation("Blocked")
  verifications      Verification[]       @relation("VerificationSubject")
  verificationsReviewed Verification[]    @relation("VerificationReviewer")
  subscriptions      Subscription[]

  @@map("users")
}

model PersonalityProfile {
  userId         String   @id @map("user_id") @db.Uuid
  quizVersion    String   @map("quiz_version")
  traitEnergy    Float    @map("trait_energy")
  traitDepth     Float    @map("trait_depth")
  traitNovelty   Float    @map("trait_novelty")
  traitStructure Float    @map("trait_structure")
  humorStyles    String[] @default([]) @map("humor_styles")
  archetype      String
  archetypeEmoji String   @map("archetype_emoji")
  embeddingId    String?  @map("embedding_id")
  completedAt    DateTime @map("completed_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("personality_profiles")
}

model QuizQuestion {
  id       String       @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  version  String
  ord      Int
  locale   String       @default("en")
  kind     QuestionKind
  text     String
  subtext  String?
  options  Json         @default("[]")
  traitKey String?      @map("trait_key")
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  responses QuizResponse[]

  @@unique([version, locale, ord])
  @@map("quiz_questions")
}

model QuizResponse {
  id         String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  questionId String   @map("question_id") @db.Uuid
  answer     Json
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  question QuizQuestion @relation(fields: [questionId], references: [id])

  @@unique([userId, questionId])
  @@map("quiz_responses")
}

// ── Geography & venues ─────────────────────────────────────────────────────

model City {
  id          String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  name        String
  slug        String   @unique
  state       String
  isLive      Boolean  @default(false) @map("is_live")
  launchOrder Int      @map("launch_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users  User[]
  venues Venue[]
  events Event[]

  @@map("cities")
}

model Venue {
  id            String        @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  cityId        String        @map("city_id") @db.Uuid
  name          String
  slug          String
  address       String
  neighborhood  String
  lat           Float
  lng           Float
  vibeTags      String[]      @default([]) @map("vibe_tags")
  priceBand     PriceBand     @map("price_band")
  capacity      Int
  partnerStatus PartnerStatus @default(prospect) @map("partner_status")
  photos        String[]      @default([])
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  city   City    @relation(fields: [cityId], references: [id])
  events Event[]

  @@unique([cityId, slug])
  @@map("venues")
}

// ── Events & booking ───────────────────────────────────────────────────────

model Event {
  id                 String      @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  cityId             String      @map("city_id") @db.Uuid
  venueId            String?     @map("venue_id") @db.Uuid // hidden from users until reveal
  type               EventType
  title              String
  slug               String      @unique
  description        String
  startsAt           DateTime    @map("starts_at") @db.Timestamptz(6)
  durationMin        Int         @map("duration_min")
  priceInr           Int         @map("price_inr")
  capacity           Int
  budgetBand         BudgetBand  @map("budget_band")
  womenOnly          Boolean     @default(false) @map("women_only")
  hostId             String?     @map("host_id") @db.Uuid
  status             EventStatus @default(draft)
  neighborhoodTeaser String?     @map("neighborhood_teaser")
  coverImage         String?     @map("cover_image")
  createdAt          DateTime    @default(now()) @map("created_at")
  updatedAt          DateTime    @updatedAt @map("updated_at")

  city        City         @relation(fields: [cityId], references: [id])
  venue       Venue?       @relation(fields: [venueId], references: [id])
  host        User?        @relation("EventHost", fields: [hostId], references: [id])
  tables      EventTable[]
  bookings    Booking[]
  matchRuns   MatchRun[]
  gameSessions GameSession[]
  connections Connection[]
  chats       Chat[]

  @@index([cityId, status, startsAt])
  @@map("events")
}

model EventTable {
  id          String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  eventId     String   @map("event_id") @db.Uuid
  tableNumber Int      @map("table_number")
  capacity    Int      @default(6)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  event            Event             @relation(fields: [eventId], references: [id], onDelete: Cascade)
  bookings         Booking[]
  matchAssignments MatchAssignment[]
  gameSessions     GameSession[]

  @@unique([eventId, tableNumber])
  @@map("event_tables")
}

model Booking {
  id        String        @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  userId    String        @map("user_id") @db.Uuid
  eventId   String        @map("event_id") @db.Uuid
  tableId   String?       @map("table_id") @db.Uuid
  status    BookingStatus @default(pending_payment)
  amountInr Int           @map("amount_inr")
  twoTruths Json?         @map("two_truths") // {truths: [a, b], lie: c} collected at booking
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  user     User         @relation(fields: [userId], references: [id])
  event    Event        @relation(fields: [eventId], references: [id])
  table    EventTable?  @relation(fields: [tableId], references: [id])
  payments Payment[]
  rating   EventRating?

  @@unique([userId, eventId]) // double-booking impossible (§6)
  @@map("bookings")
}

model Payment {
  id                String        @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  bookingId         String?       @map("booking_id") @db.Uuid
  subscriptionId    String?       @map("subscription_id") @db.Uuid
  provider          String
  providerOrderId   String        @map("provider_order_id")
  providerPaymentId String?       @map("provider_payment_id")
  amountInr         Int           @map("amount_inr")
  status            PaymentStatus @default(created)
  raw               Json          @default("{}")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  booking      Booking?      @relation(fields: [bookingId], references: [id])
  subscription Subscription? @relation(fields: [subscriptionId], references: [id])

  @@map("payments")
}

// ── Matching ───────────────────────────────────────────────────────────────

model MatchRun {
  id           String         @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  eventId      String         @map("event_id") @db.Uuid
  algoVersion  String         @map("algo_version")
  params       Json           @default("{}")
  status       MatchRunStatus @default(running)
  scoreSummary Json?          @map("score_summary")
  createdBy    String         @map("created_by") @db.Uuid
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  event       Event             @relation(fields: [eventId], references: [id])
  creator     User              @relation("MatchRunCreator", fields: [createdBy], references: [id])
  assignments MatchAssignment[]

  @@map("match_runs")
}

model MatchAssignment {
  id         String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  matchRunId String   @map("match_run_id") @db.Uuid
  tableId    String   @map("table_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  tableScore Float    @map("table_score")
  explain    Json     @default("{}")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  matchRun MatchRun   @relation(fields: [matchRunId], references: [id], onDelete: Cascade)
  table    EventTable @relation(fields: [tableId], references: [id])
  user     User       @relation(fields: [userId], references: [id])

  @@unique([matchRunId, userId])
  @@map("match_assignments")
}

// ── Games ──────────────────────────────────────────────────────────────────

model Deck {
  id        String     @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  kind      DeckKind
  locale    DeckLocale @default(en)
  title     String
  level     Int? // icebreakers: 1|2|3
  source    DeckSource @default(seed)
  status    DeckStatus @default(draft)
  deletedAt DateTime?  @map("deleted_at")
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  cards        DeckCard[]
  gameSessions GameSession[]

  @@map("decks")
}

model DeckCard {
  id             String    @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  deckId         String    @map("deck_id") @db.Uuid
  ord            Int
  text           String
  answer         String? // trivia only
  tags           String[]  @default([])
  safetyReviewed Boolean   @default(false) @map("safety_reviewed")
  deletedAt      DateTime? @map("deleted_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  deck Deck @relation(fields: [deckId], references: [id], onDelete: Cascade)

  @@unique([deckId, ord])
  @@map("deck_cards")
}

model GameSession {
  id        String    @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  tableId   String    @map("table_id") @db.Uuid
  eventId   String    @map("event_id") @db.Uuid
  deckId    String    @map("deck_id") @db.Uuid
  state     Json      @default("{}") // {phase, current_card, votes, scores, level}
  startedBy String    @map("started_by") @db.Uuid
  startedAt DateTime  @default(now()) @map("started_at")
  endedAt   DateTime? @map("ended_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  table   EventTable @relation(fields: [tableId], references: [id])
  event   Event      @relation(fields: [eventId], references: [id])
  deck    Deck       @relation(fields: [deckId], references: [id])
  starter User       @relation("GameStarter", fields: [startedBy], references: [id])

  @@map("game_sessions")
}

// ── Post-event ─────────────────────────────────────────────────────────────

model EventRating {
  id          String    @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  bookingId   String    @unique @map("booking_id") @db.Uuid
  overall     Int // 1–5, checked in service layer
  hostRating  Int?      @map("host_rating")
  venueRating Int?      @map("venue_rating")
  feedback    String?
  deletedAt   DateTime? @map("deleted_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  booking Booking @relation(fields: [bookingId], references: [id])

  @@map("event_ratings")
}

model Connection {
  id         String           @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  eventId    String           @map("event_id") @db.Uuid
  fromUserId String           @map("from_user") @db.Uuid
  toUserId   String           @map("to_user") @db.Uuid
  kind       ConnectionKind
  status     ConnectionStatus @default(pending)
  createdAt  DateTime         @default(now()) @map("created_at")
  updatedAt  DateTime         @updatedAt @map("updated_at")

  event    Event @relation(fields: [eventId], references: [id])
  fromUser User  @relation("ConnectionFrom", fields: [fromUserId], references: [id])
  toUser   User  @relation("ConnectionTo", fields: [toUserId], references: [id])

  // Sparks require BOTH users open_to_dating — enforced in service layer + tested (§6).
  @@unique([eventId, fromUserId, toUserId, kind])
  @@map("connections")
}

model Chat {
  id        String    @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  kind      ChatKind
  eventId   String?   @map("event_id") @db.Uuid
  expiresAt DateTime? @map("expires_at") // table groups expire T+7d
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  event    Event?       @relation(fields: [eventId], references: [id])
  members  ChatMember[]
  messages Message[]

  @@map("chats")
}

model ChatMember {
  chatId   String   @map("chat_id") @db.Uuid
  userId   String   @map("user_id") @db.Uuid
  joinedAt DateTime @default(now()) @map("joined_at")

  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@id([chatId, userId])
  @@map("chat_members")
}

model Message {
  id        String      @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  chatId    String      @map("chat_id") @db.Uuid
  senderId  String      @map("sender_id") @db.Uuid
  body      String
  kind      MessageKind @default(text)
  deletedAt DateTime?   @map("deleted_at")
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  chat   Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender User @relation(fields: [senderId], references: [id])

  @@index([chatId, createdAt])
  @@map("messages")
}

// ── Trust & safety ─────────────────────────────────────────────────────────

model Report {
  id         String       @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  reporterId String       @map("reporter_id") @db.Uuid
  reportedId String       @map("reported_id") @db.Uuid
  eventId    String?      @map("event_id") @db.Uuid
  reason     ReportReason
  details    String
  status     ReportStatus @default(open)
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")

  reporter User @relation("Reporter", fields: [reporterId], references: [id])
  reported User @relation("Reported", fields: [reportedId], references: [id])

  @@map("reports")
}

model Block {
  blockerId String   @map("blocker_id") @db.Uuid
  blockedId String   @map("blocked_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  blocker User @relation("Blocker", fields: [blockerId], references: [id])
  blocked User @relation("Blocked", fields: [blockedId], references: [id])

  @@id([blockerId, blockedId])
  @@map("blocks")
}

model Verification {
  id         String             @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  userId     String             @map("user_id") @db.Uuid
  kind       VerificationKind
  status     VerificationStatus @default(pending)
  mediaUrl   String             @map("media_url")
  reviewedBy String?            @map("reviewed_by") @db.Uuid
  createdAt  DateTime           @default(now()) @map("created_at")
  updatedAt  DateTime           @updatedAt @map("updated_at")

  user     User  @relation("VerificationSubject", fields: [userId], references: [id])
  reviewer User? @relation("VerificationReviewer", fields: [reviewedBy], references: [id])

  @@map("verifications")
}

// ── Membership ─────────────────────────────────────────────────────────────

model Subscription {
  id               String             @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  userId           String             @map("user_id") @db.Uuid
  tier             SubscriptionTier
  status           SubscriptionStatus @default(active)
  providerSubId    String?            @map("provider_sub_id")
  currentPeriodEnd DateTime           @map("current_period_end")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id])
  payments Payment[]

  @@map("subscriptions")
}
